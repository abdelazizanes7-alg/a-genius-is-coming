import random
import string
# the project is about a password generator
print("welcome to password generator")
# the user have to put the numbers he wants
total=int(input("enter the total number of characters in the password:\n"))
letter=int(input("enter the number of letters in the password:\n"))
number=int(input("enter the number of numbers in the password:\n"))
symbole=int(input("enter the number of symboles in the password:\n"))

count=letter+number+symbole
if count==total:
    # now we will choose all numbers,symboles and letters
    total1=[]
    numbers=string.digits
    letters=string.ascii_letters
    symboles=string.punctuation
    # now we choose randomly according to the numbers the user wants
    t_numbers=random.choices(numbers,k=number)
    t_letters=random.choices(letters,k=letter)
    t_symboles=random.choices(symboles,k=symbole)
    # we transfere to our list
    total1.extend(t_numbers)
    total1.extend(t_letters)
    total1.extend(t_symboles)
    # we mix
    random.shuffle(total1)
    # now we will suggest the password
    print("the perfect password is:\n"+ "".join(total1))
    
else:
    print("invalid input, please check again")
    
